#loops
#a loop executes a block of code multiple times until a condition is false or sequence is finished.

#for loop
#used when we know how many time to run(work with list, tuple, string, dict.,range).
for i in range(5):
    print("hello", i)   #will print how many time the range is written
    
#while loop
#used when we don't know exact repetitions; runs until condition is false

count = 1
while count <= 5:
    print("Hello",count)
    count += 1
    
#loop control
#break = exit loop immediately
#continue = skip current iteration 
#pass = do nothing (paceholder)
for i in range(1, 6):
    if i == 3:
        continue
    if i== 5:
        break
    print(i)
    
#nested loop
#loop inside another loop
for i in range(2):
    for j in range(3):
        print("i=",i,"j=",j) #need gap of four in each case otherwise it will show error
        
